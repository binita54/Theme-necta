{{!
    @template theme_necta/login

    NECTA Learn — branded split login (Design Guide §1); form uses core/loginform.
}}
{{> theme_boost/head }}

<body {{{ bodyattributes }}}>
{{> core/local/toast/wrapper}}

<div id="page-wrapper" class="d-print-block">

    {{{ output.standard_top_of_body_html }}}

    <div id="page" class="necta-login-page container-fluid px-0">
        <div class="row g-0 necta-login-split">
            <aside class="col-lg-5 necta-login-brand d-none d-lg-flex flex-column justify-content-center" aria-hidden="false">
                <div class="necta-login-brand-inner">
                    {{#logourl}}
                    <img class="necta-login-brand-logo mb-4" src="{{logourl}}" alt="{{sitename_full}}" width="200" height="60" decoding="async" />
                    {{/logourl}}
                    <h1 class="necta-login-brand-title h2 mb-2">{{sitename_full}}</h1>
                    <p class="necta-login-brand-tagline mb-0">{{#str}}login_tagline, theme_necta{{/str}}</p>
                </div>
            </aside>
            <div class="col-12 col-lg-7 necta-login-form-col d-flex align-items-center justify-content-center py-5 px-3 px-lg-5">
                <div class="necta-login-card w-100">
                    <div class="login-wrapper">
                        <div class="login-container">
                            {{{ output.main_content }}}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{> theme_necta/footer }}
</div>

</body>
</html>
{{#js}}
M.util.js_pending('theme_boost/loader');
require(['theme_boost/loader'], function() {
  M.util.js_complete('theme_boost/loader');
});
{{/js}}
